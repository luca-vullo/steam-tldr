{
  "name": "steam-tldr",
  "version": "0.2.0",
  "private": true,
  "description": "Chrome extension that generates an AI TL;DR of a game's recent Steam reviews, right on its store page",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.2.0",
    "@types/chrome": "^0.2.2",
    "typescript": "^7.0.2",
    "vite": "^6.4.3"
  },
  "dependencies": {
    "@anthropic-ai/foundry-sdk": "^0.4.0",
    "@anthropic-ai/sdk": "^0.111.0"
  }
}
